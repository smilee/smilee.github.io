---
interface Props {
  variant?: 'loader' | 'hero' | 'nav';
  class?: string;
}

const { variant = 'hero', class: className = '' } = Astro.props;

const sizes = {
  loader: { width: 140, height: 160 },
  hero: { width: 280, height: 320 },
  nav: { width: 35, height: 40 },
};

const { width, height } = sizes[variant];
---

<svg
  class:list={['logo', `logo--${variant}`, className]}
  viewBox="0 0 28 32"
  width={width}
  height={height}
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Seungmin logo"
>
  <!-- Path 1: Top loop through left loop -->
  <path
    class="logo__path logo__path--1"
    d="M13.98,11.874
      c3.65,0,6.813-4.848,4.356-7.936c-1.016-1.276-2.699-1.595-4.247-1.606c-2.557-0.017-5.051,1.843-5.882,4.232
      c-1.43,4.111,3.831,6.32,4.57,9.979c0.466,2.306-0.805,4.905-3.262,5.291C8.457,22,7.371,21.783,6.357,21.434
      c-0.886-0.305-1.743-0.715-2.48-1.292c-1.189-0.93-2.016-2.274-1.831-3.821C2.204,14.99,3.04,13.78,4.17,13.079
      c0.518-0.322,1.102-0.538,1.709-0.613"
  />

  <!-- Path 2: Right loop through tail -->
  <path
    class="logo__path logo__path--2"
    d="M15.992,18.453
      c1.296,1.586,2.941,2.981,4.935,3.106c1.552,0.097,3.086-0.745,3.988-2.011c0.902-1.266,1.207-2.901,1.008-4.443
      c-0.167-1.301-0.807-2.681-1.975-3.366c-3.924-2.302-7.257,4.918-8.338,7.554c-1.173,2.86-2.043,5.857-3.533,8.564
      c-0.376,0.683-0.838,1.387-1.562,1.677c-0.698,0.28-1.529,0.1-2.126-0.357c-1.203-0.92-1.62-2.827-0.347-3.889
      c1.762-1.47,3.934,0.862,5.323,1.788c1.123,0.748,3.475,2.78,5.026,2.299"
  />

  <!-- Connector 1: Left diagonal -->
  <path
    class="logo__path logo__connector logo__connector--1"
    d="M13.117,11.726 c-1.099,1.851-3.03,4.304-4.552,6.082"
  />

  <!-- Connector 2: Right diagonal -->
  <path
    class="logo__path logo__connector logo__connector--2"
    d="M19.396,17.808 c-1.522-1.778-3.453-4.231-4.552-6.083"
  />

  <!-- Circle: Left -->
  <circle
    class="logo__circle logo__circle--left"
    cx="7.137"
    cy="19.407"
    r="2.144"
  />

  <!-- Circle: Right -->
  <circle
    class="logo__circle logo__circle--right"
    cx="20.824"
    cy="19.407"
    r="2.144"
  />

  <!-- Circle: Top (larger) -->
  <circle
    class="logo__circle logo__circle--top"
    cx="13.981"
    cy="9.26"
    r="2.612"
  />
</svg>

<style>
  .logo {
    --logo-stroke: var(--color-text, #1a1a1a);
    display: block;
  }

  .logo__path,
  .logo__circle {
    fill: none;
    stroke: var(--logo-stroke);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-miterlimit: 10;
  }

  /* ========== Loader Variant: Sketch Draw-on ========== */
  .logo--loader .logo__path--1 {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: sketch-path-1 1.4s cubic-bezier(0.4, 0, 0.2, 1) 0.1s forwards;
  }

  .logo--loader .logo__path--2 {
    stroke-dasharray: 120;
    stroke-dashoffset: 120;
    animation: sketch-path-2 1.6s cubic-bezier(0.4, 0, 0.2, 1) 0.6s forwards;
  }

  .logo--loader .logo__connector--1 {
    stroke-dasharray: 20;
    stroke-dashoffset: 20;
    animation: sketch-connector 0.5s cubic-bezier(0.4, 0, 0.2, 1) 1.1s forwards;
  }

  .logo--loader .logo__connector--2 {
    stroke-dasharray: 20;
    stroke-dashoffset: 20;
    animation: sketch-connector 0.5s cubic-bezier(0.4, 0, 0.2, 1) 1.3s forwards;
  }

  .logo--loader .logo__circle--left {
    stroke-dasharray: 13.5;
    stroke-dashoffset: 13.5;
    animation: sketch-circle 0.6s cubic-bezier(0.4, 0, 0.2, 1) 1.5s forwards;
  }

  .logo--loader .logo__circle--right {
    stroke-dasharray: 13.5;
    stroke-dashoffset: 13.5;
    animation: sketch-circle 0.6s cubic-bezier(0.4, 0, 0.2, 1) 1.0s forwards;
  }

  .logo--loader .logo__circle--top {
    stroke-dasharray: 16.4;
    stroke-dashoffset: 16.4;
    animation: sketch-circle 0.7s cubic-bezier(0.4, 0, 0.2, 1) 0.35s forwards;
  }

  @keyframes sketch-path-1 {
    to { stroke-dashoffset: 0; }
  }

  @keyframes sketch-path-2 {
    to { stroke-dashoffset: 0; }
  }

  @keyframes sketch-connector {
    to { stroke-dashoffset: 0; }
  }

  @keyframes sketch-circle {
    to { stroke-dashoffset: 0; }
  }

  /* ========== Hero Variant: Fade in after loader ========== */
  .logo--hero {
    opacity: 0;
    animation: hero-fade-in 0.8s var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)) 2.2s forwards;
  }

  @keyframes hero-fade-in {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* ========== Nav Variant: Subtle hover effect ========== */
  .logo--nav {
    transition: transform 0.3s var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1));
  }

  .logo--nav:hover {
    transform: scale(1.05);
  }

  /* ========== Reduced Motion ========== */
  @media (prefers-reduced-motion: reduce) {
    .logo--loader .logo__path,
    .logo--loader .logo__circle {
      stroke-dasharray: none;
      stroke-dashoffset: 0;
      animation: none;
    }

    .logo--hero {
      opacity: 1;
      animation: none;
    }
  }
</style>
