---
interface Props {
  variant?: 'loader' | 'hero' | 'nav';
  class?: string;
}

const { variant = 'hero', class: className = '' } = Astro.props;

const sizes = {
  loader: { width: 140, height: 160 },
  hero: { width: 280, height: 320 },
  nav: { width: 35, height: 40 },
};

const { width, height } = sizes[variant];
---

<svg
  class:list={['logo', `logo--${variant}`, className]}
  viewBox="0 0 28 32"
  width={width}
  height={height}
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Seungmin logo"
>
  <!-- Main curves group -->
  <g>
    <!-- Path 1: S curve -->
    <path
      class="logo__path logo__path--1"
      d="M14,11.9c3,0,5.5-3.1,5.2-6-.2-1.4-1.1-2.4-2.3-3-1.1-.5-2.3-.7-3.4-.5-1.3.2-2.5.8-3.4,1.6-.8.7-1.5,1.6-1.8,2.6-.5,1.6,0,3.2.9,4.5s1.6,1.9,2.3,2.9c1.1,1.6,1.8,3.6,1,5.4-1,2.2-3.4,2.8-5.7,2.2-2.3-.6-5.1-2.5-4.8-5.2.2-1.3,1-2.5,2.1-3.2.5-.3,1.1-.5,1.7-.6"
    />

    <!-- Path 2: L curve -->
    <path
      class="logo__path logo__path--2"
      d="M15.1,18.6c1.3,1.6,3.7,2.9,5.7,3,1.6,0,3.2-.7,4.1-2,.9-1.3,1.2-2.9,1-4.4-.2-1.3-.8-2.7-2-3.4-2.4-1.4-4.9.9-6.4,2.7-2.2,2.8-3.5,6.2-4.7,9.5-.1.4-.3.8-.4,1.1-.4,1-.7,2-1.2,2.8s-1.4,1.8-2.5,1.6c-1.7-.4-1.9-3.3-.7-4.3,1.4-1.2,3.1.2,4.3,1.1,2.2,1.6,5.2,3.7,8.1,3.1"
    />
  </g>

  <!-- Nodes group (renders on top) -->
  <g>
    <!-- Circle: Top -->
    <circle
      class="logo__circle logo__circle--top"
      cx="14"
      cy="9.6"
      r="2.3"
    />

    <!-- Connector 1: Left curved -->
    <path
      class="logo__path logo__connector logo__connector--1"
      d="M11.8,10.4c-2.7,1.5-4.2,4.3-4.6,7.4"
    />

    <!-- Circle: Left -->
    <circle
      class="logo__circle logo__circle--left"
      cx="7.1"
      cy="19.7"
      r="1.9"
    />

    <!-- Connector 2: Right curved -->
    <path
      class="logo__path logo__connector logo__connector--2"
      d="M16.2,10.4c2.7,1.5,4.2,4.3,4.6,7.4"
    />

    <!-- Circle: Right -->
    <circle
      class="logo__circle logo__circle--right"
      cx="20.8"
      cy="19.7"
      r="1.9"
    />
  </g>
</svg>

<style>
  .logo {
    --logo-stroke: var(--color-brand, #1E5B43);
    display: block;
  }

  .logo__path,
  .logo__circle {
    fill: none;
    stroke: var(--logo-stroke);
    stroke-width: 0.8px;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-miterlimit: 10;
  }

  /* ========== Loader Variant: Sketch everything ========== */

  /* Path 1: S curve - draws first */
  .logo--loader .logo__path--1 {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: sketch-draw 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.1s forwards;
  }

  /* Path 2: L curve - draws second */
  .logo--loader .logo__path--2 {
    stroke-dasharray: 120;
    stroke-dashoffset: 120;
    animation: sketch-draw 0.9s cubic-bezier(0.4, 0, 0.2, 1) 0.7s forwards;
  }

  /* Top circle - sketches after main curves */
  .logo--loader .logo__circle--top {
    stroke-dasharray: 14.5; /* 2 * PI * 2.3 */
    stroke-dashoffset: 14.5;
    animation: sketch-draw 0.4s cubic-bezier(0.4, 0, 0.2, 1) 1.4s forwards;
  }

  /* Left connector - sketches from top circle */
  .logo--loader .logo__connector--1 {
    stroke-dasharray: 12;
    stroke-dashoffset: 12;
    animation: sketch-draw 0.3s cubic-bezier(0.4, 0, 0.2, 1) 1.6s forwards;
  }

  /* Left circle - sketches at end of left connector */
  .logo--loader .logo__circle--left {
    stroke-dasharray: 12; /* 2 * PI * 1.9 */
    stroke-dashoffset: 12;
    animation: sketch-draw 0.35s cubic-bezier(0.4, 0, 0.2, 1) 1.8s forwards;
  }

  /* Right connector - sketches from top circle */
  .logo--loader .logo__connector--2 {
    stroke-dasharray: 12;
    stroke-dashoffset: 12;
    animation: sketch-draw 0.3s cubic-bezier(0.4, 0, 0.2, 1) 1.65s forwards;
  }

  /* Right circle - sketches at end of right connector */
  .logo--loader .logo__circle--right {
    stroke-dasharray: 12; /* 2 * PI * 1.9 */
    stroke-dashoffset: 12;
    animation: sketch-draw 0.35s cubic-bezier(0.4, 0, 0.2, 1) 1.85s forwards;
  }

  @keyframes sketch-draw {
    to { stroke-dashoffset: 0; }
  }

  /* ========== Hero Variant: Fade in after loader ========== */
  .logo--hero {
    opacity: 0;
    animation: hero-fade-in 0.8s var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)) 2.2s forwards;
  }

  @keyframes hero-fade-in {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* ========== Nav Variant: Subtle hover effect ========== */
  .logo--nav {
    transition: transform 0.3s var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1));
  }

  .logo--nav:hover {
    transform: scale(1.05);
  }

  /* ========== Reduced Motion ========== */
  @media (prefers-reduced-motion: reduce) {
    .logo--loader .logo__path,
    .logo--loader .logo__circle {
      stroke-dasharray: none;
      stroke-dashoffset: 0;
      animation: none;
    }

    .logo--hero {
      opacity: 1;
      animation: none;
    }
  }
</style>
