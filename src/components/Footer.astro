---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { name: 'GitHub', url: 'https://github.com/smilee', icon: 'github' },
  { name: 'LinkedIn', url: 'https://linkedin.com/in/seungmin-lee-luovanori', icon: 'linkedin' },
  { name: 'Email', url: 'mailto:seungmin@uxplus.dev', icon: 'mail' },
];
---

<footer class="footer">
  <div class="footer__container">
    <div class="footer__content">
      <div class="footer__cta reveal">
        <h2 class="footer__title">Let's build something together</h2>
        <a href="mailto:seungmin@uxplus.dev" class="footer__email" data-cursor="interactive">
          seungmin@uxplus.dev
        </a>
      </div>

      <nav class="footer__social reveal" aria-label="Social links">
        <ul class="footer__social-list">
          {
            socialLinks.map((link) => (
              <li>
                <a
                  href={link.url}
                  class="footer__social-link"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={link.name}
                  data-cursor="interactive"
                >
                  {link.icon === 'github' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                    </svg>
                  )}
                  {link.icon === 'linkedin' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                      <rect x="2" y="9" width="4" height="12" />
                      <circle cx="4" cy="4" r="2" />
                    </svg>
                  )}
                  {link.icon === 'mail' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                      <polyline points="22,6 12,13 2,6" />
                    </svg>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {currentYear} Seungmin. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-xl) var(--gutter) var(--space-lg);
  }

  .footer__container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-subtle);
  }

  .footer__cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .footer__title {
    font-size: var(--text-2xl);
    font-weight: 500;
  }

  .footer__email {
    font-size: var(--text-lg);
    color: var(--color-muted);
    position: relative;
    transition: color 0.2s ease;
  }

  .footer__email::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s var(--ease-out);
  }

  .footer__email:hover {
    color: var(--color-text);
  }

  .footer__email:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .footer__social-list {
    list-style: none;
    padding: 0;
    display: flex;
    gap: var(--space-sm);
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    color: var(--color-muted);
    transition:
      color 0.2s ease,
      background 0.2s ease,
      transform 0.2s ease;
  }

  .footer__social-link:hover {
    color: var(--color-text);
    background: var(--color-subtle);
    transform: translateY(-2px);
  }

  .footer__bottom {
    padding-top: var(--space-md);
    text-align: center;
  }

  .footer__copyright {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .footer__title {
      font-size: var(--text-xl);
    }
  }
</style>
